<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    tools:context=".MainActivity">

    <!-- Toolbar (hidden — we use custom header instead) -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/toolbarContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:elevation="0dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="88dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp">

            <!-- ── GREETING HEADER ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_5">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good morning,"
                        android:textAppearance="@style/TextAppearance.SnapBudget.BodySmall" />

                    <TextView
                        android:id="@+id/tvAppName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SnapBudget 👋"
                        android:textAppearance="@style/TextAppearance.SnapBudget.Headline2"
                        android:layout_marginTop="1dp" />
                </LinearLayout>

                <!-- Logo -->
                <FrameLayout
                    android:id="@+id/avatarContainer"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_avatar">

                    <ImageView
                        android:id="@+id/ivLogo"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_app_logo"
                        android:contentDescription="SnapBudget Logo" />
                </FrameLayout>
            </LinearLayout>

            <!-- ── BALANCE / SPENDING CARD ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMonthlyTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_4"
                app:cardCornerRadius="@dimen/radius_xl"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bg_monthly_card"
                app:strokeColor="@color/brand_alpha_20"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_5">

                    <!-- Label monospace caps -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MONTHLY SPENDING"
                        android:textAppearance="@style/TextAppearance.SnapBudget.LabelSmall"
                        android:textColor="@color/brand_alpha_70" />

                    <!-- Big amount -->
                    <TextView
                        android:id="@+id/tvMonthlyTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="₹0"
                        android:textAppearance="@style/TextAppearance.SnapBudget.Headline1" />

                    <!-- Sub label -->
                    <TextView
                        android:id="@+id/tvCurrentMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="March 2026"
                        android:textAppearance="@style/TextAppearance.SnapBudget.BodySmall" />

                    <!-- Budget progress bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="5dp"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_progress_track">

                        <View
                            android:id="@+id/progressBudget"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="62"
                            android:background="@drawable/bg_progress_fill" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="38" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── QUICK ACTIONS 2-COL GRID ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:layout_marginBottom="@dimen/spacing_6">

                <!-- Scan Receipt — PRIMARY filled green button -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_1_5"
                    style="@style/Widget.SnapBudget.ActionCard.Primary">

                    <LinearLayout
                        android:id="@+id/btnScanReceipt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <!-- Lightning icon -->
                        <FrameLayout
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_marginEnd="10dp">
                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_flash_on"
                                app:tint="@color/on_brand"
                                android:importantForAccessibility="no" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Scan"
                                android:textAppearance="@style/TextAppearance.SnapBudget.BodyMedium"
                                android:textColor="@color/on_brand"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Receipt"
                                android:textAppearance="@style/TextAppearance.SnapBudget.Caption"
                                android:textColor="@color/black_alpha_60" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- History — SECONDARY outlined/ghost button -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_1_5"
                    style="@style/Widget.SnapBudget.ActionCard.Secondary">

                    <LinearLayout
                        android:id="@+id/btnViewHistory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <!-- Clock icon box -->
                        <FrameLayout
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_marginEnd="10dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="⏱"
                                android:textSize="16sp" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="History"
                                android:textAppearance="@style/TextAppearance.SnapBudget.BodyMedium"
                                android:textColor="@color/brand"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="All records"
                                android:textAppearance="@style/TextAppearance.SnapBudget.Caption" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ── CATEGORY PIE CHART CARD ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_6"
                app:cardCornerRadius="@dimen/radius_xl"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bg_surface"
                app:strokeColor="@color/border_subtle"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/spacing_5"
                    android:paddingTop="@dimen/spacing_4"
                    android:paddingBottom="@dimen/spacing_2">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CATEGORY BREAKDOWN"
                        android:textAppearance="@style/TextAppearance.SnapBudget.LabelSmall"
                        android:layout_marginBottom="4dp" />

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/pieChart"
                        android:layout_width="match_parent"
                        android:layout_height="260dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── RECENT TRANSACTIONS HEADER ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_3">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="RECENT TRANSACTIONS"
                    android:textAppearance="@style/TextAppearance.SnapBudget.LabelSmall" />

                <TextView
                    android:id="@+id/tvViewAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View all"
                    android:textAppearance="@style/TextAppearance.SnapBudget.BodySmall"
                    android:textColor="@color/brand"
                    android:textStyle="bold"
                    android:padding="@dimen/spacing_1" />
            </LinearLayout>

            <!-- ── TRANSACTION LIST ── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvNoTransactions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="48dp"
                    android:text="No transactions yet.\nScan a receipt to get started."
                    android:textColor="@color/text_tertiary"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerRecentTransactions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_transaction" />
            </FrameLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB — Scan Receipt -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAddManual"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="20dp"
        android:text="Scan Receipt"
        android:textColor="@color/on_brand"
        android:textStyle="bold"
        android:textSize="14sp"
        app:icon="@android:drawable/ic_menu_camera"
        app:iconTint="@color/on_brand"
        app:backgroundTint="@color/brand"
        app:elevation="6dp"
        app:cornerRadius="100dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>