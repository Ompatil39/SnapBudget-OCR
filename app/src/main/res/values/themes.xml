<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme — Dark First -->
    <style name="Theme.SnapBudgetOCR" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Brand -->
        <item name="colorPrimary">@color/brand</item>
        <item name="colorOnPrimary">@color/on_brand</item>
        <item name="colorPrimaryContainer">@color/brand_glow</item>
        <item name="colorOnPrimaryContainer">@color/brand</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/info</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Error -->
        <item name="colorError">@color/danger</item>
        <item name="colorOnError">@color/black</item>

        <!-- Status bar & navigation -->
        <item name="android:statusBarColor">@color/bg_base</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/bg_base</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>

        <!-- Surfaces -->
        <item name="android:windowBackground">@color/bg_base</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/bg_elevated</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/border_soft</item>
        <item name="colorSurfaceContainerHigh">@color/bg_overlay</item>

        <!-- Dropdown / Popup Style -->
        <item name="listPopupWindowStyle">@style/Widget.App.ListPopupWindow</item>
    </style>

    <style name="Widget.App.ListPopupWindow" parent="Widget.AppCompat.ListPopupWindow">
        <item name="android:popupBackground">@color/bg_overlay</item>
    </style>

    <style name="Theme.SnapBudgetOCR.ActionBar" parent="Theme.Material3.Dark">
        <item name="colorPrimary">@color/brand</item>
        <item name="colorOnPrimary">@color/on_brand</item>
    </style>

    <!-- Card Style — Dark elevated surfaces -->
    <style name="CardStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/radius_xl</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/bg_surface</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/border_subtle</item>
        <item name="android:layout_marginBottom">@dimen/spacing_3</item>
    </style>

    <style name="Widget.SnapBudget.ActionCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Widget.SnapBudget.ActionCard.Primary">
        <item name="cardBackgroundColor">@color/brand</item>
    </style>

    <style name="Widget.SnapBudget.ActionCard.Secondary">
        <item name="cardBackgroundColor">@android:color/transparent</item>
        <item name="strokeColor">@color/brand</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Typography -->
    <style name="TextAppearance.SnapBudget.Headline1" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">30sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.SnapBudget.Headline2" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.SnapBudget.TitleText" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.SnapBudget.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.SnapBudget.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.SnapBudget.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.SnapBudget.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/text_tertiary</item>
    </style>

    <style name="TextAppearance.SnapBudget.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">9sp</item>
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.14</item>
    </style>

    <style name="AmountText">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/brand</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TitleText">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="LabelText">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <!-- Button Styles -->
    <style name="ActionButton" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="backgroundTint">@color/bg_elevated</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="ActionButton.Brand" parent="Widget.Material3.Button">
        <item name="cornerRadius">100dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="backgroundTint">@color/brand</item>
        <item name="android:textColor">@color/on_brand</item>
    </style>

    <style name="ActionButton.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="backgroundTint">@color/brand_subtle</item>
        <item name="android:textColor">@color/brand</item>
    </style>

</resources>